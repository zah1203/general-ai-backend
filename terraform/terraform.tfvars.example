aws_region       = "us-east-1"
project_name     = "genorax-ai-backend"
environment      = "dev"
instance_type    = "t3.micro"
key_name         = "your-ec2-keypair-name"
allowed_ssh_cidr = "YOUR_PUBLIC_IP/32"
allowed_api_cidr = "YOUR_PUBLIC_IP/32"
github_repo_url  = "https://github.com/<your-org-or-user>/genorax-ai-backend.git"
